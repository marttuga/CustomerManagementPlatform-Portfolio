## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools. If you are
## developing with Visual Studio, the VS .gitignore
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
## has more thorough IDE-specific entries.
##
## Get latest from https://github.com/github/gitignore/blob/main/Dotnet.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg

# Others
~$*
*~
CodeCoverage/

# MSBuild Binary and Structured Log
*.binlog

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml
.fake

# SQLite database - never commit real data
*.db
*.db-shm
*.db-wal

# Angular production build
**/wwwroot/

# Pen drive build output - regenerated by build_pen.bat
pen_output/

# rclone credentials - real config with live token must never be committed
# (only the sanitized rclone.conf.example is tracked)
deploy/tools/rclone.conf

# rclone binary - not needed in the repo, download separately if running the pen drive build
deploy/tools/rclone.exe

# Cypress generated files
cypress/videos/
cypress/screenshots/

# Node modules
**/node_modules/

# IDE / editor
.vs/
.idea/
*.user
*.suo

# Angular build cache
.angular/

# Environment variables
.env
.env.local
.env.*.local

# ASP.NET Core secrets (only if you ever use dotnet user-secrets)
secrets.json